# Скопируйте в .env и заполните
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
# URL куда Telegram будет слать POST запросы, например: https://yourdomain.com/your_bot_username
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/your_bot_username
# Ваш Telegram user_id (получить у @userinfobot)
TELEGRAM_ALLOWED_USER_ID=123456789
