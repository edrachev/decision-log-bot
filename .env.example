# Скопируйте в .env и заполните (нужно на VPS в /opt/decision-log-bot/.env)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
# Ваш Telegram user_id (получить у @userinfobot)
TELEGRAM_ALLOWED_USER_ID=123456789
# Путь к SQLite файлу (опционально, по умолчанию ./data/decisionlog.db)
# DATABASE_PATH=/data/decisionlog.db
# Docker Hub username — нужен для docker-compose image pull
DOCKERHUB_USERNAME=your_dockerhub_username
